 buf.clear();
 let mut body = sender.body.0;
 let mut tx = Some(sender.tx);
 loop { if Some(written) == con_len { return Ok(()); } if buf.is_empty() { if buf.capacity() == buf.len() { buf.reserve(8192); let uninit = buf.spare_capacity_mut(); let uninit_len = uninit.len(); unsafe { ptr::write_bytes(uninit.as_mut_ptr().cast::<u8>(), 0, uninit_len); } } let bytes = unsafe { mem::transmute::<&mut [MaybeUninit<u8>], &mut [u8]>(buf.spare_capacity_mut()) }; match body.read(bytes) { Ok(0) => { return Ok(()); } Ok(n) => unsafe { buf.advance_mut(n); }, Err(e) => { let _ = tx.take().expect("tx only taken on error").clone().try_send(Err(Abort)); return Err(crate::error::body(e)); } } } let buf_len = buf.len() as u64; tx.as_mut().expect("tx only taken on error").send(Ok(buf.split().freeze())).await.map_err(crate::error::body) ?; written += buf_len; }
}

