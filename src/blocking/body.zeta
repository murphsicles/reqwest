fn send_future(sender: Sender) -> Result<(), crate::Error> {
 use bytes::{ BufMut, BytesMut };
 use futures_util::SinkExt;
 use std::cmp;
 let con_len = sender.body.1;
 let cap = cmp::min(sender.body.1.unwrap_or(8192), 8192);
